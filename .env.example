# ── Local dev (copy to .env.local) ──────────────────────────────────────────

# Doubao voice credentials — used by proxy.js only, never expose to frontend
DOUBAO_APP_ID=
# Prefer ACCESS_TOKEN (from Volcengine console); ACCESS_KEY also works as fallback
DOUBAO_ACCESS_TOKEN=
DOUBAO_ACCESS_KEY=

# Report generation (local report-server / Vercel api/generate-report)
DEEPSEEK_API_KEY=

# ── Frontend (Vite — also set in Vercel dashboard) ─────────────────────────

# WebSocket proxy URL
# Local:  ws://localhost:8080
# Prod:   wss://your-proxy.up.railway.app
VITE_VOICE_PROXY_URL=ws://localhost:8080

# Supabase (enables generate-report Edge Function instead of local report-server)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Railway (voice proxy service) ───────────────────────────────────────────

# Comma-separated list of allowed frontend origins
# Example: https://xiaobang-voice-coach.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
