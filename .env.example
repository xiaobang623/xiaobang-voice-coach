# ── Local dev (copy to .env.local) ──────────────────────────────────────────

# Doubao voice credentials — used by proxy.js only, never expose to frontend
DOUBAO_APP_ID=
# Prefer ACCESS_TOKEN (from Volcengine console); ACCESS_KEY also works as fallback
DOUBAO_ACCESS_TOKEN=
DOUBAO_ACCESS_KEY=

# Report generation (local report-server / Vercel api/generate-report)
DEEPSEEK_API_KEY=
# SiliconFlow — cloud ASR/TTS for self-hosted voice backend (server-side only)
SILICONFLOW_API_KEY=
# Optional override (default https://api.siliconflow.cn/v1)
# SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1
# SiliconFlow TTS emotion/style — off by default; enabling prepends it to every sentence and adds ~0.3-0.7s first-chunk latency each
# SILICONFLOW_TTS_INSTRUCT=Speak with warm, lively American English...<|endofprompt|>
# TTS warmup/filler experiments — off by default because cloud warmup can compete with the user's first real reply
# TTS_WARMUP_ENABLED=false
# TTS_FILLER_DELAY_MS=0
# Cost model.
# Defaults are intentionally conservative estimates; override per model when you know the exact vendor price.
# DeepSeek fallback cost per 1M tokens in CNY (default: 2)
DEEPSEEK_COST_PER_1M_TOKENS=2
# Optional model-specific override, e.g. DEEPSEEK_DEEPSEEK_CHAT_COST_PER_1M_TOKENS=2
# SiliconFlow fallback TTS cost per 1k characters in CNY (default: 0.05)
SILICONFLOW_COST_PER_1K_CHARS=0.05
# Optional model-specific overrides
SILICONFLOW_COSYVOICE_COST_PER_1K_CHARS=0.05
SILICONFLOW_MOSS_TTSD_COST_PER_1K_CHARS=0.05
# Doubao realtime speech cost per minute in CNY (default: 0.4) — duration fallback
DOUBAO_COST_PER_MINUTE=0.4
# Doubao cost per 1M tokens in CNY — used when proxy reports official UsageResponse tokens
DOUBAO_COST_PER_1M_TOKENS=
# Optional model-specific overrides
DOUBAO_SPEECH_DIALOG_COST_PER_MINUTE=0.4
DOUBAO_SPEECH_DIALOG_COST_PER_1M_TOKENS=

# Admin dashboard (Vercel api/admin/*)
JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
# One-time admin password reset via POST /api/admin/auth/reset (remove after use)
ADMIN_RESET_SECRET=

# ── Frontend (Vite — also set in Vercel dashboard) ─────────────────────────

# WebSocket proxy URL
# Local:  ws://localhost:8080
# Prod:   wss://your-proxy.up.railway.app
VITE_VOICE_PROXY_URL=ws://localhost:8080
# Self-hosted voice backend (platform-native ASR / Whisper + DeepSeek + TTS)
# Local:  ws://localhost:8081/ws
# Prod:   wss://your-selfhosted-voice.up.railway.app/ws  (deploy backend/server.js via railway.selfhosted.toml)
VITE_SELFHOSTED_VOICE_URL=ws://localhost:8081/ws

# Set to "false" to hide the typing-test toggle in production
# VITE_ENABLE_TYPING_TEST=false

# Supabase (auth, storage, growth page)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Set to "true" to route generate-report + extract-memory to Supabase Edge Functions
# (requires deploying both functions with DEEPSEEK_API_KEY secret)
VITE_USE_SUPABASE_FUNCTIONS=
WHISPER_BASE_URL=http://127.0.0.1:8000
# Whisper: 留空或 auto = 自动检测语言（推荐）；en/zh 可强制单语（更快）
# WHISPER_LANG=
WHISPER_DEVICE=mps
COSYVOICE_BASE_URL=http://127.0.0.1:8001
# CosyVoice: cpu avoids garbled MPS output on torch 2.3; fp16 only helps on CUDA
COSYVOICE_DEVICE=cpu
COSYVOICE_FP16=false
PYTORCH_ENABLE_MPS_FALLBACK=1
SELFHOSTED_VOICE_PORT=8081
# Local dev API server port (npm run dev:api). Default 3099 — avoid 3000 if another app uses it.
# DEV_API_PORT=3099
# Self-hosted model instance registry (server-side only; admin UI selects keys)
# Example: {"whisper":{"base":"http://127.0.0.1:8000","large-v3":"http://127.0.0.1:8010"},"cosyvoice":{"cosyvoice2-0.5b":"http://127.0.0.1:8001"}}
# VOICE_MODEL_INSTANCES=

# ── Railway (voice proxy service) ───────────────────────────────────────────

# Comma-separated list of allowed frontend origins
# Example: https://xiaobang-voice-coach.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
# Where proxy POSTs Doubao usage logs (Vercel app origin, no trailing slash)
USAGE_LOG_BASE_URL=https://xiaobang-voice-coach.vercel.app

# ── Voice proxy auth (堵烧钱洞：必须在 Vercel 和 Railway 两边配同一个值) ──────
# 语音代理鉴权密钥（HMAC）。同一个值要同时配到 Vercel（签发 /api/issue-voice-token）
# 和 Railway proxy（校验）。未设置时 proxy 放行所有连接（灰度用），对外开放前务必设上。
# 生成：openssl rand -hex 32
VOICE_TOKEN_SECRET=
# 每日会话上限（防刷；不填用默认：游客 3、登录用户 30）
GUEST_DAILY_SESSION_LIMIT=3
USER_DAILY_SESSION_LIMIT=30
