# ── Local dev (copy to .env.local) ──────────────────────────────────────────

# Doubao voice credentials — used by proxy.js only, never expose to frontend
DOUBAO_APP_ID=
# Prefer ACCESS_TOKEN (from Volcengine console); ACCESS_KEY also works as fallback
DOUBAO_ACCESS_TOKEN=
DOUBAO_ACCESS_KEY=

# Report generation (local report-server / Vercel api/generate-report)
DEEPSEEK_API_KEY=
# DeepSeek cost per 1M tokens in CNY (default: 2)
DEEPSEEK_COST_PER_1M_TOKENS=2
# Doubao realtime speech cost per minute in CNY (default: 0.4) — duration fallback
DOUBAO_COST_PER_MINUTE=0.4
# Doubao cost per 1M tokens in CNY — used when proxy reports official UsageResponse tokens
DOUBAO_COST_PER_1M_TOKENS=

# Admin dashboard (Vercel api/admin/*)
JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
# One-time admin password reset via POST /api/admin/auth/reset (remove after use)
ADMIN_RESET_SECRET=

# ── Frontend (Vite — also set in Vercel dashboard) ─────────────────────────

# WebSocket proxy URL
# Local:  ws://localhost:8080
# Prod:   wss://your-proxy.up.railway.app
VITE_VOICE_PROXY_URL=ws://localhost:8080

# Set to "false" to hide the typing-test toggle in production
# VITE_ENABLE_TYPING_TEST=false

# Supabase (auth, storage, growth page)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Set to "true" to route generate-report + extract-memory to Supabase Edge Functions
# (requires deploying both functions with DEEPSEEK_API_KEY secret)
VITE_USE_SUPABASE_FUNCTIONS=

# ── Railway (voice proxy service) ───────────────────────────────────────────

# Comma-separated list of allowed frontend origins
# Example: https://xiaobang-voice-coach.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
# Where proxy POSTs Doubao usage logs (Vercel app origin, no trailing slash)
USAGE_LOG_BASE_URL=https://xiaobang-voice-coach.vercel.app
