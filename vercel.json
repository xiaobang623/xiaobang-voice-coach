{
  "rewrites": [
    { "source": "/api/admin", "destination": "/api/admin.js" },
    { "source": "/api/admin/(.*)", "destination": "/api/admin.js?path=$1" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/admin/:path*", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/admin.js": {
      "maxDuration": 30
    },
    "api/generate-report.js": {
      "maxDuration": 60
    }
  }
}
